{
  "name": "transcritoria-desktop",
  "version": "1.0.0",
  "description": "TranscritorIA Desktop",
  "main": "electron/main.js",
  "author": "TranscritorIA",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:backend\" \"npm:dev:frontend\" \"npm:dev:electron\"",
    "dev:backend": ".\\.venv\\Scripts\\python.exe backend\\app_entry.py",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:electron": "wait-on tcp:3000 tcp:8000 && cross-env ELECTRON_DEV=1 electron .",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "npm --prefix frontend run build",
    "build:backend": ".\\.venv\\Scripts\\python.exe -m pip install pyinstaller && .\\.venv\\Scripts\\python.exe -m PyInstaller backend\\pyinstaller_backend.spec --noconfirm",
    "package": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder"
  },
  "devDependencies": {
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.transcritoria.desktop",
    "productName": "TranscritorIA",
    "files": [
      "electron/**/*",
      "frontend/out/**/*",
      "frontend/public/**/*"
    ],
    "extraResources": [
      {
        "from": "dist/backend.exe",
        "to": "backend/backend.exe"
      },
      {
        "from": "resources/ffmpeg",
        "to": "ffmpeg"
      }
    ],
    "asar": true,
    "win": {
      "signAndEditExecutable": false,
      "forceCodeSigning": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "TranscritorIA"
    }
  }
}
